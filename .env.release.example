# Tauri updater signing private key.
# Path or full key content both work.
TAURI_SIGNING_PRIVATE_KEY="$HOME/.tauri/review-please.key"
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=""

# Updater public key baked into the app at build time.
# You can set the content directly or point at a file.
# TAURI_UPDATER_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----..."
TAURI_UPDATER_PUBLIC_KEY_FILE="$HOME/.tauri/review-please.key.pub"

# Change this only if you publish from a different repository.
GITHUB_REPOSITORY="sycha-front/pr-review-please"
